{
  "admin": {
    "listen": "0.0.0.0:2019",
    "origins": ["caddy:2019", "localhost:2019", "127.0.0.1:2019", ""],
    "enforce_origin": false
  },
  "apps": {
    "http": {
      "servers": {
        "updraft": {
          "listen": [":80"],
          "routes": [
            {
              "@id": "api-route",
              "match": [{ "path": ["/api/*"] }],
              "handle": [
                {
                  "handler": "subroute",
                  "routes": [
                    {
                      "handle": [
                        {
                          "handler": "rewrite",
                          "strip_path_prefix": "/api"
                        },
                        {
                          "handler": "reverse_proxy",
                          "upstreams": [{ "dial": "api:8088" }]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "@id": "frontend-route",
              "match": [{ "path": ["/*"] }],
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "upstreams": [{ "dial": "frontend:3000" }]
                }
              ]
            }
          ]
        }
      }
    }
  }
}
